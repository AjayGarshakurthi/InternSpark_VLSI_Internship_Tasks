DESIGN MODULE
module alu (
    input  wire [7:0] A,
    input  wire [7:0] B,
    input  wire [2:0] opcode,
    output reg  [7:0] result,
    output reg  zero
);

always @(*) begin
    case (opcode)
        3'b000: result = A + B;
        3'b001: result = A - B;
        3'b010: result = A & B;
        3'b011: result = A | B;
        3'b100: result = A ^ B;
        default: result = 8'b0;
    endcase

    zero = (result == 8'b0);
end

endmodule

